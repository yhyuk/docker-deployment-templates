# Server Configuration
SERVER_PORT=8080

# Spring Profile
SPRING_PROFILE=prod

# Database Configuration
DB_NAME=app_db
DB_USER=app_user
DB_ROOT_PASSWORD=       # 필수: MySQL root 비밀번호
DB_PASSWORD=            # 필수: 애플리케이션 DB 비밀번호
DB_PORT=3306

# JPA Configuration
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
